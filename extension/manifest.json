{
  "manifest_version": 3,
  "name": "NinjaPrice Picker",
  "version": "1.0.0",
  "description": "Add products to your local NinjaPrice tracker, with automatic price detection.",
  "icons": {
    "48": "icon.png",
    "128": "icon.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["activeTab", "scripting"],
  "host_permissions": ["http://localhost:65452/*"]
}
